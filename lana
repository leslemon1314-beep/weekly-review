<header>
  <h1>週複盤</h1>
  <p>回顧目標・評估結果・分析原因・總結規律</p>
  <div class="stones">
    <span class="stone b"></span><span class="stone w"></span><span class="stone b"></span>
  </div>
</header>

<button id="helpBtn" aria-label="什麼是複盤" title="什麼是複盤?">?</button>

<div id="helpOverlay" class="help-overlay" hidden>
  <div class="help-modal" role="dialog" aria-modal="true" aria-labelledby="helpTitle">
    <button id="helpClose" class="help-close" aria-label="關閉說明">×</button>
    <h2 id="helpTitle">什麼是複盤?</h2>
    <p class="help-intro">複盤源自圍棋術語,核心是做完一件事後,系統性回顧過程、提煉可複用的經驗,而不只是「感覺不錯」的空泛總結。</p>
    <div class="help-steps">
      <div class="help-step">
        <span class="help-num">1</span>
        <div><strong>回顧目標</strong><p>當初想達成什麼?</p></div>
      </div>
      <div class="help-step">
        <span class="help-num">2</span>
        <div><strong>評估結果</strong><p>實際發生了什麼,差距在哪?</p></div>
      </div>
      <div class="help-step">
        <span class="help-num">3</span>
        <div><strong>分析原因</strong><p>最關鍵的一步:誠實拆解成功是實力還是運氣、失敗是計畫還是執行問題。</p></div>
      </div>
      <div class="help-step">
        <span class="help-num">4</span>
        <div><strong>總結規律</strong><p>哪些經驗可以複製到下一次?</p></div>
      </div>
    </div>
    <p class="help-tip">小提醒:別只看結果、不看過程——結果好不代表過程判斷都對,可能只是運氣好。</p>
  </div>
</div>

<div class="wrap">
  <div class="weeknav">
    <button id="prevWeek" aria-label="上一週">‹</button>
    <div class="weeklabel">
      <div class="y" id="weekLabel"></div>
      <div class="r" id="weekRange"></div>
    </div>
    <button id="nextWeek" aria-label="下一週">›</button>
  </div>

  <div class="section plan">
    <div class="section-title"><span class="dot"></span>本週計畫</div>
    <div id="taskList" class="task-list"></div>
    <button id="addTaskBtn" class="add-task-btn">+ 新增項目</button>
  </div>

  <div class="section work">
    <div class="section-title"><span class="dot"></span>工作</div>
    <div class="field">
      <label>目標:這週原本要達成什麼?</label>
      <textarea data-key="work_goal" rows="2" placeholder="沒設目標也沒關係,可以問自己:如果這週順利,原本希望是什麼樣子?"></textarea>
    </div>
    <div class="field">
      <label>結果:實際發生了什麼?差距在哪?</label>
      <textarea data-key="work_result" rows="2" placeholder="用事實和數據描述,不靠印象"></textarea>
    </div>
    <div class="field">
      <label>原因:順利或卡關的根本原因是什麼?</label>
      <textarea data-key="work_reason" rows="2" placeholder="多問幾次「為什麼」,挖到根本原因"></textarea>
    </div>
    <div class="field">
      <label>行動:下週要多做、少做、開始做什麼?</label>
      <textarea data-key="work_action" rows="2" placeholder="沒頭緒的話,可以延續上一週寫的行動"></textarea>
    </div>
  </div>

  <div class="section life">
    <div class="section-title"><span class="dot"></span>生活</div>
    <div class="field">
      <label>這週做得好的一件事,為什麼?</label>
      <textarea data-key="life_good" rows="2" placeholder="沒特別的事也可以寫:哪個小時刻讓我感覺還不錯?"></textarea>
    </div>
    <div class="field">
      <label>有什麼讓我不舒服或後悔的?真正原因是什麼?</label>
      <textarea data-key="life_bad" rows="2" placeholder="別急著下結論,先描述當下發生了什麼"></textarea>
    </div>
    <div class="field">
      <label>時間都花在哪?符合我想要的優先順序嗎?</label>
      <textarea data-key="life_time" rows="2" placeholder="回想這週的行事曆或訊息紀錄,大部分時間花在哪裡"></textarea>
    </div>
    <div class="field">
      <label>下週想調整的一個小行動?</label>
      <textarea data-key="life_action" rows="2" placeholder="一個具體行動就好,不用貪多"></textarea>
    </div>
  </div>

  <div class="actions">
    <button class="save-btn" id="saveBtn">儲存這週複盤</button>
    <span class="save-status" id="saveStatus"></span>
  </div>

  <div class="history">
    <div class="history-title">歷史紀錄</div>
    <div class="history-list" id="historyList"></div>
  </div>
</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getDatabase, ref, set, onValue, off } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";
  import { firebaseConfig } from "./firebase-config.js";

  var app = initializeApp(firebaseConfig);
  var db = getDatabase(app);

  var fields = ['work_goal','work_result','work_reason','work_action','life_good','life_bad','life_time','life_action'];

  function getISOWeek(d){
    var date = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
    var dayNum = date.getUTCDay() || 7;
    date.setUTCDate(date.getUTCDate() + 4 - dayNum);
    var yearStart = new Date(Date.UTC(date.getUTCFullYear(),0,1));
    var weekNo = Math.ceil((((date - yearStart) / 86400000) + 1) / 7);
    return {year: date.getUTCFullYear(), week: weekNo};
  }
  function weekKey(y,w){ return y + '-W' + String(w).padStart(2,'0'); }
  function getMondayOfWeek(y,w){
    var jan4 = new Date(Date.UTC(y,0,4));
    var jan4Day = jan4.getUTCDay() || 7;
    var monday = new Date(jan4);
    monday.setUTCDate(jan4.getUTCDate() - jan4Day + 1 + (w-1)*7);
    return monday;
  }
  function fmtRange(y,w){
    var mon = getMondayOfWeek(y,w);
    var sun = new Date(mon); sun.setUTCDate(mon.getUTCDate()+6);
    var f = function(d){ return (d.getUTCMonth()+1) + '/' + String(d.getUTCDate()).padStart(2,'0'); };
    return f(mon) + ' - ' + f(sun);
  }

  var today = new Date();
  var cur = getISOWeek(today);
  var currentTasks = [];
  var currentRef = null;
  var suppressNextChange = false;

  var defaultTasks = [
    {date:'2026-07-12', task:'問主管,若缺工具後續處理流程(跨線借調/申請)大概怎麼跑、要多久', note:'先問清楚,避免卡住不知道怎麼配合', done:false},
    {date:'2026-07-13', task:'報工後:列印第一款車種爆炸圖 → 確認扭力範圍 → 跑現場核對工具', note:'邊做邊記錄:去了哪、花多久、有沒有找到', done:false},
    {date:'2026-07-13', task:'若缺工具,彙整清單告知主管', note:'', done:false},
    {date:'2026-07-14', task:'列印第二款車種爆炸圖,重複核對流程', note:'對照第一次花的時間,看有沒有變快', done:false},
    {date:'2026-07-15', task:'開線', note:'事後複盤:哪裡卡、哪裡比預期順', done:false}
  ];
  var planWeekKey = weekKey(getISOWeek(new Date(2026,6,12)).year, getISOWeek(new Date(2026,6,12)).week);

  function render(){
    document.getElementById('weekLabel').textContent = cur.year + ' 第 ' + cur.week + ' 週';
    document.getElementById('weekRange').textContent = fmtRange(cur.year, cur.week);
    watchCurrentWeek();
  }

  function applyData(data){
    data = data || {};
    fields.forEach(function(k){
      document.querySelector('[data-key="'+k+'"]').value = data[k] || '';
    });
    var key = weekKey(cur.year, cur.week);
    currentTasks = (data.tasks && data.tasks.length)
      ? data.tasks
      : (key === planWeekKey ? JSON.parse(JSON.stringify(defaultTasks)) : [{date:'', task:'', note:'', done:false}]);
    renderTasks(currentTasks);
  }

  function watchCurrentWeek(){
    var status = document.getElementById('saveStatus');
    status.textContent = '連線中...';
    if(currentRef) off(currentRef);
    var key = weekKey(cur.year, cur.week);
    currentRef = ref(db, 'reviews/' + key);
    onValue(currentRef, function(snapshot){
      status.textContent = '';
      applyData(snapshot.val());
    }, function(){
      status.textContent = '無法連線,請檢查網路';
    });
  }

  document.getElementById('saveBtn').addEventListener('click', function(){
    var status = document.getElementById('saveStatus');
    var data = { savedAt: new Date().toISOString() };
    fields.forEach(function(k){ data[k] = document.querySelector('[data-key="'+k+'"]').value; });
    data.tasks = currentTasks.filter(function(t){ return t.task || t.date || t.note; });
    status.textContent = '儲存中...';
    set(ref(db, 'reviews/' + weekKey(cur.year, cur.week)), data).then(function(){
      status.textContent = '已儲存';
    }).catch(function(){
      status.textContent = '儲存失敗';
    });
  });

  document.getElementById('prevWeek').addEventListener('click', function(){
    cur.week -= 1;
    if(cur.week < 1){ cur.year -= 1; cur.week = 52; }
    render();
  });
  document.getElementById('nextWeek').addEventListener('click', function(){
    cur.week += 1;
    if(cur.week > 53){ cur.year += 1; cur.week = 1; }
    render();
  });

  function renderHistory(allData){
    var list = document.getElementById('historyList');
    var keys = Object.keys(allData || {}).sort().reverse();
    if(keys.length === 0){
      list.innerHTML = '<div class="empty">還沒有任何紀錄。</div>';
      return;
    }
    list.innerHTML = '';
    keys.forEach(function(wk){
      var data = allData[wk] || {};
      var snippet = data.work_goal || data.life_good || '';
      var item = document.createElement('div');
      item.className = 'history-item';
      item.innerHTML = '<span class="wk">' + wk + '</span><span class="snippet">' + snippet.replace(/</g,'&lt;') + '</span>';
      item.addEventListener('click', function(){
        var parts = wk.split('-W');
        cur = { year: parseInt(parts[0]), week: parseInt(parts[1]) };
        render();
      });
      list.appendChild(item);
    });
  }

  onValue(ref(db, 'reviews'), function(snapshot){
    renderHistory(snapshot.val());
  });

  function renderTasks(tasks){
    var list = document.getElementById('taskList');
    list.innerHTML = '';
    tasks.forEach(function(t, idx){
      var row = document.createElement('div');
      row.className = 'task-row' + (t.done ? ' done' : '');
      row.innerHTML =
        '<input type="checkbox" ' + (t.done ? 'checked' : '') + ' data-field="done">' +
        '<input type="date" value="' + (t.date || '') + '" data-field="date">' +
        '<input type="text" placeholder="要做的事" value="' + (t.task || '').replace(/"/g,'&quot;') + '" data-field="task">' +
        '<input type="text" placeholder="備註" value="' + (t.note || '').replace(/"/g,'&quot;') + '" data-field="note">' +
        '<button class="task-del" aria-label="刪除項目">×</button>';
      row.querySelector('[data-field="done"]').addEventListener('change', function(e){
        t.done = e.target.checked;
        row.classList.toggle('done', t.done);
      });
      row.querySelector('[data-field="date"]').addEventListener('input', function(e){ t.date = e.target.value; });
      row.querySelector('[data-field="task"]').addEventListener('input', function(e){ t.task = e.target.value; });
      row.querySelector('[data-field="note"]').addEventListener('input', function(e){ t.note = e.target.value; });
      row.querySelector('.task-del').addEventListener('click', function(){
        tasks.splice(idx,1);
        renderTasks(tasks);
      });
      list.appendChild(row);
    });
  }

  document.getElementById('addTaskBtn').addEventListener('click', function(){
    currentTasks.push({date:'', task:'', note:'', done:false});
    renderTasks(currentTasks);
  });

  render();

  var helpBtn = document.getElementById('helpBtn');
  var helpOverlay = document.getElementById('helpOverlay');
  var helpClose = document.getElementById('helpClose');
  function openHelp(){ helpOverlay.hidden = false; }
  function closeHelp(){ helpOverlay.hidden = true; }
  helpBtn.addEventListener('click', openHelp);
  helpClose.addEventListener('click', closeHelp);
  helpOverlay.addEventListener('click', function(e){
    if(e.target === helpOverlay) closeHelp();
  });
  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && !helpOverlay.hidden) closeHelp();
  });
</script>
</body>
</html>

