<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#20211d;
    --paper:#f6f4ee;
    --paper-2:#ffffff;
    --board:#b98d4f;
    --board-line:#8a6a3a;
    --stone-black:#20211d;
    --stone-white:#fbfaf6;
    --work:#3b6b5a;
    --work-bg:#e7f0ec;
    --life:#a24c3a;
    --life-bg:#f7e9e3;
    --muted:#8b8a80;
    --border:#e1ddd0;
    --shadow:0 1px 2px rgba(32,33,29,0.06);
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter', -apple-system, 'PingFang TC', 'Microsoft JhengHei', sans-serif;
    line-height:1.6;
  }
  .wrap{
    max-width:760px;
    margin:0 auto;
    padding:0 20px 80px;
  }
  header{
    position:relative;
    padding:56px 20px 40px;
    text-align:center;
    background:
      linear-gradient(var(--board-line) 1px, transparent 1px) 0 0/28px 28px,
      linear-gradient(90deg, var(--board-line) 1px, transparent 1px) 0 0/28px 28px,
      var(--board);
    background-blend-mode:overlay;
    overflow:hidden;
  }
  header::before{
    content:"";
    position:absolute; inset:0;
    background:radial-gradient(ellipse at center, transparent 0%, var(--paper) 78%);
  }
  header h1{
    position:relative;
    font-family:'Noto Serif TC', serif;
    font-weight:700;
    font-size:34px;
    margin:0 0 6px;
    letter-spacing:0.04em;
  }
  header p{
    position:relative;
    margin:0;
    color:var(--ink);
    font-size:14px;
    opacity:0.72;
  }
  .stones{
    position:relative;
    display:flex;
    justify-content:center;
    gap:8px;
    margin-top:18px;
  }
  .stone{
    width:12px;height:12px;border-radius:50%;
  }
  .stone.b{background:var(--stone-black);}
  .stone.w{background:var(--stone-white); border:1px solid var(--board-line);}

  .weeknav{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:22px;
    margin:-28px 0 32px;
    position:relative;
  }
  .weeknav button{
    width:36px;height:36px;
    border-radius:50%;
    border:1px solid var(--border);
    background:var(--paper-2);
    box-shadow:var(--shadow);
    cursor:pointer;
    font-size:16px;
    color:var(--ink);
  }
  .weeknav button:hover{background:var(--paper);}
  .weeklabel{
    background:var(--paper-2);
    border:1px solid var(--border);
    border-radius:12px;
    padding:10px 22px;
    text-align:center;
    box-shadow:var(--shadow);
    min-width:160px;
  }
  .weeklabel .y{font-family:'Noto Serif TC', serif; font-weight:700; font-size:17px;}
  .weeklabel .r{font-size:12px; color:var(--muted); margin-top:2px;}

  .section{
    background:var(--paper-2);
    border:1px solid var(--border);
    border-radius:14px;
    padding:22px 24px;
    margin-bottom:20px;
    box-shadow:var(--shadow);
  }
  .section-title{
    display:flex; align-items:center; gap:10px;
    font-family:'Noto Serif TC', serif;
    font-weight:700;
    font-size:17px;
    margin-bottom:18px;
  }
  .dot{width:10px;height:10px;border-radius:50%;}
  .section.work .dot{background:var(--work);}
  .section.life .dot{background:var(--life);}
  .section.work .section-title{color:var(--work);}
  .section.life .section-title{color:var(--life);}

  .field{margin-bottom:16px;}
  .field:last-child{margin-bottom:0;}
  .field label{
    display:block;
    font-size:13px;
    color:var(--muted);
    margin-bottom:6px;
  }
  .field textarea{
    width:100%;
    border:1px solid var(--border);
    border-radius:8px;
    padding:10px 12px;
    font-family:inherit;
    font-size:14px;
    color:var(--ink);
    background:var(--paper);
    resize:vertical;
    min-height:52px;
  }
  .section.work .field textarea:focus{outline:none; border-color:var(--work); background:var(--work-bg);}
  .section.life .field textarea:focus{outline:none; border-color:var(--life); background:var(--life-bg);}

  .actions{
    display:flex;
    align-items:center;
    gap:14px;
    margin:28px 0 40px;
  }
  .save-btn{
    flex:1;
    padding:13px;
    border:none;
    border-radius:10px;
    background:var(--ink);
    color:var(--paper);
    font-size:15px;
    font-weight:500;
    cursor:pointer;
    font-family:'Noto Serif TC', serif;
    letter-spacing:0.02em;
  }
  .save-btn:hover{background:#3a3b34;}
  .save-status{font-size:13px; color:var(--muted); min-width:60px;}

  .history{
    border-top:1px solid var(--border);
    padding-top:22px;
  }
  .history-title{
    font-size:13px;
    font-weight:500;
    color:var(--muted);
    margin-bottom:12px;
    text-transform:uppercase;
    letter-spacing:0.05em;
  }
  .history-list{display:grid; gap:8px;}
  .history-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:10px 14px;
    background:var(--paper-2);
    border:1px solid var(--border);
    border-radius:8px;
    cursor:pointer;
    font-size:13px;
  }
  .history-item:hover{border-color:var(--board-line);}
  .history-item .wk{font-weight:500;}
  .history-item .snippet{color:var(--muted); font-size:12px; margin-left:12px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; text-align:right;}
  .empty{color:var(--muted); font-size:13px; padding:8px 2px;}

  .topnav{
    max-width:760px;
    margin:0 auto;
    padding:16px 20px 0;
    display:flex;
    gap:16px;
    font-size:13px;
  }
  .topnav a{
    color:var(--muted);
    text-decoration:none;
    padding:4px 0;
    border-bottom:1px solid transparent;
  }
  .topnav a:hover{color:var(--ink); border-color:var(--board-line);}
  .topnav a.current{color:var(--ink); font-weight:500; border-color:var(--board-line);}

  #helpBtn{
    position:fixed;
    right:22px; bottom:22px;
    width:44px; height:44px;
    border-radius:50%;
    border:1px solid var(--board-line);
    background:var(--ink);
    color:var(--paper);
    font-family:'Noto Serif TC', serif;
    font-size:18px;
    font-weight:700;
    cursor:pointer;
    box-shadow:0 2px 8px rgba(32,33,29,0.25);
    z-index:10;
  }
  #helpBtn:hover{background:#3a3b34;}

  .help-overlay{
    position:fixed; inset:0;
    background:rgba(32,33,29,0.45);
    display:flex; align-items:center; justify-content:center;
    padding:20px;
    z-index:20;
  }
  .help-overlay[hidden]{display:none;}
  .help-modal{
    position:relative;
    background:var(--paper-2);
    border-radius:16px;
    max-width:440px;
    width:100%;
    max-height:86vh;
    overflow-y:auto;
    padding:32px 28px 26px;
    box-shadow:0 8px 30px rgba(32,33,29,0.3);
  }
  .help-modal h2{
    font-family:'Noto Serif TC', serif;
    font-size:22px;
    margin:0 0 12px;
  }
  .help-close{
    position:absolute; top:14px; right:14px;
    width:30px; height:30px;
    border-radius:50%;
    border:1px solid var(--border);
    background:var(--paper);
    font-size:16px;
    cursor:pointer;
    color:var(--ink);
  }
  .help-close:hover{background:var(--paper-2); border-color:var(--board-line);}
  .help-intro{font-size:14px; color:var(--ink); margin:0 0 20px;}
  .help-steps{display:grid; gap:14px; margin-bottom:20px;}
  .help-step{display:flex; gap:12px; align-items:flex-start;}
  .help-num{
    flex:none;
    width:24px; height:24px;
    border-radius:50%;
    background:var(--board);
    color:var(--stone-white);
    font-size:12px; font-weight:700;
    display:flex; align-items:center; justify-content:center;
    margin-top:1px;
  }
  .help-step strong{font-size:14px;}
  .help-step p{margin:2px 0 0; font-size:13px; color:var(--muted);}
  .section.plan .dot{background:var(--board-line);}
  .section.plan .section-title{color:var(--board-line);}
  .task-list{display:grid; gap:8px; margin-bottom:12px;}
  .task-row{
    display:grid;
    grid-template-columns:auto 92px 1fr 1fr auto;
    gap:8px;
    align-items:center;
  }
  .task-row input[type="checkbox"]{
    width:18px; height:18px;
    accent-color:var(--board-line);
    cursor:pointer;
  }
  .task-row input[type="date"],
  .task-row input[type="text"]{
    border:1px solid var(--border);
    border-radius:8px;
    padding:8px 10px;
    font-family:inherit;
    font-size:13px;
    color:var(--ink);
    background:var(--paper);
    width:100%;
  }
  .task-row.done input[type="text"]{
    color:var(--muted);
    text-decoration:line-through;
  }
  .task-del{
    border:none;
    background:none;
    color:var(--muted);
    font-size:16px;
    cursor:pointer;
    width:26px; height:26px;
  }
  .task-del:hover{color:var(--life);}
  .add-task-btn{
    border:1px dashed var(--border);
    background:none;
    border-radius:8px;
    padding:8px 12px;
    font-size:13px;
    color:var(--muted);
    cursor:pointer;
    width:100%;
  }
  .add-task-btn:hover{border-color:var(--board-line); color:var(--ink);}
  .help-tip{
    font-size:12px;
    color:var(--muted);
    border-top:1px solid var(--border);
    padding-top:14px;
    margin:0;
  }
  @media (max-width:520px){
    .task-row{grid-template-columns:auto 1fr auto; grid-template-areas:"check date del" "check task task" "check note note";}
    .task-row input[type="checkbox"]{grid-area:check;}
    .task-row input[type="date"]{grid-area:date;}
    .task-row input[data-field="task"]{grid-area:task;}
    .task-row input[data-field="note"]{grid-area:note;}
    .task-del{grid-area:del;}
  }
</style>
</head>
