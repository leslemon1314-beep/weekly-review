<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import { getDatabase, ref, set, onValue, off } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";
  import { firebaseConfig } from "./firebase-config.js";

  var app = initializeApp(firebaseConfig);
  var db = getDatabase(app);

  var weekdayNames = ['日','一','二','三','四','五','六'];

  function toKey(d){
    var y = d.getFullYear();
    var m = String(d.getMonth()+1).padStart(2,'0');
    var day = String(d.getDate()).padStart(2,'0');
    return y + '-' + m + '-' + day;
  }
  function fmtLabel(d){
    return (d.getMonth()+1) + '月' + d.getDate() + '日';
  }
  function fmtWeekday(d){
    return '星期' + weekdayNames[d.getDay()];
  }

  var cur = new Date();
  cur.setHours(0,0,0,0);

  var seedTasks = {
    '2026-07-12': [
      {task:'問主管:若缺工具,後續處理流程(跨線借調/申請)大概怎麼跑、要多久', note:'先問清楚,避免卡住不知道怎麼配合', status:'doing'}
    ],
    '2026-07-13': [
      {task:'報工後列印第一款車種爆炸圖', note:'', status:'doing'},
      {task:'確認扭力範圍', note:'', status:'waiting'},
      {task:'跑現場核對工具', note:'邊做邊記錄:去了哪、花多久、有沒有找到', status:'waiting'},
      {task:'若缺工具,彙整清單告知主管', note:'', status:'waiting'}
    ],
    '2026-07-14': [
      {task:'列印第二款車種爆炸圖', note:'', status:'doing'},
      {task:'重複核對扭力範圍與現場工具', note:'對照第一次花的時間,看有沒有變快', status:'waiting'}
    ],
    '2026-07-15': [
      {task:'開線', note:'', status:'doing'},
      {task:'事後複盤:哪裡卡、哪裡比預期順', note:'', status:'waiting'}
    ]
  };

  function autoGrow(el){
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }

  var currentTasks = [];
  var currentRef = null;

  function render(){
    document.getElementById('dayLabel').textContent = fmtLabel(cur);
    document.getElementById('dayRange').textContent = fmtWeekday(cur);
    watchCurrentDay();
  }

  function watchCurrentDay(){
    var status = document.getElementById('saveStatus');
    status.textContent = '連線中...';
    if(currentRef) off(currentRef);
    var key = toKey(cur);
    currentRef = ref(db, 'dayTasks/' + key);
    onValue(currentRef, function(snapshot){
      status.textContent = '';
      var data = snapshot.val();
      if(data && data.tasks && data.tasks.length){
        currentTasks = data.tasks;
      }else if(seedTasks[key]){
        currentTasks = JSON.parse(JSON.stringify(seedTasks[key]));
      }else{
        currentTasks = [{task:'', note:'', status:'waiting'}];
      }
      currentTasks.forEach(function(t){ if(!t.status) t.status = t.done ? 'done' : 'waiting'; });
      renderTasks();
    }, function(){
      status.textContent = '無法連線,請檢查網路';
    });
  }

  function updateProgress(){
    var total = currentTasks.filter(function(t){ return t.task; }).length;
    var done = currentTasks.filter(function(t){ return t.task && t.status === 'done'; }).length;
    var pct = total ? Math.round((done/total)*100) : 0;
    document.getElementById('progressBar').style.width = pct + '%';
  }

  var statusLabels = {doing:'執行中', waiting:'等待中', done:'已完成'};

  function setStatus(t, newStatus){
    if(newStatus === 'doing'){
      currentTasks.forEach(function(other){
        if(other !== t && other.status === 'doing') other.status = 'waiting';
      });
    }
    t.status = newStatus;
  }

  function renderTasks(){
    var list = document.getElementById('taskList');
    list.innerHTML = '';

    var doing = currentTasks.filter(function(t){ return t.status === 'doing'; });
    var waiting = currentTasks.filter(function(t){ return t.status === 'waiting'; });
    var done = currentTasks.filter(function(t){ return t.status === 'done'; });

    var doingTitle = document.createElement('div');
    doingTitle.className = 'group-title';
    doingTitle.textContent = '專注 · 執行中';
    list.appendChild(doingTitle);
    if(doing.length === 0){
      var empty = document.createElement('div');
      empty.className = 'focus-empty';
      empty.textContent = '目前沒有進行中的任務,從下面等待中的項目挑一件開始。';
      list.appendChild(empty);
    }else{
      doing.forEach(function(t){ list.appendChild(buildRow(t)); });
    }

    var waitingTitle = document.createElement('div');
    waitingTitle.className = 'group-title';
    waitingTitle.textContent = '等待中';
    list.appendChild(waitingTitle);
    if(waiting.length === 0){
      var e2 = document.createElement('div');
      e2.className = 'focus-empty';
      e2.textContent = '沒有等待中的項目。';
      list.appendChild(e2);
    }else{
      waiting.forEach(function(t){ list.appendChild(buildRow(t)); });
    }

    if(done.length > 0){
      var doneTitle = document.createElement('div');
      doneTitle.className = 'group-title';
      doneTitle.textContent = '已完成';
      list.appendChild(doneTitle);
      done.forEach(function(t){ list.appendChild(buildRow(t)); });
    }

    updateProgress();
  }

  function buildRow(t){
    var row = document.createElement('div');
    row.className = 'task-row' + (t.status === 'doing' ? ' doing' : '') + (t.status === 'done' ? ' done' : '');
    var options = ['doing','waiting','done'].map(function(s){
      return '<option value="' + s + '"' + (t.status === s ? ' selected' : '') + '>' + statusLabels[s] + '</option>';
    }).join('');
    row.innerHTML =
      '<div class="task-row-top">' +
        '<select data-field="status">' + options + '</select>' +
        '<textarea rows="1" placeholder="要做的事" data-field="task">' + (t.task || '') + '</textarea>' +
        '<button class="task-del" aria-label="刪除項目">×</button>' +
      '</div>' +
      '<textarea rows="1" placeholder="備註" data-field="note">' + (t.note || '') + '</textarea>';
    row.querySelector('[data-field="status"]').addEventListener('change', function(e){
      setStatus(t, e.target.value);
      renderTasks();
    });
    var taskEl = row.querySelector('[data-field="task"]');
    var noteEl = row.querySelector('[data-field="note"]');
    autoGrow(taskEl);
    autoGrow(noteEl);
    taskEl.addEventListener('input', function(e){ t.task = e.target.value; updateProgress(); autoGrow(e.target); });
    noteEl.addEventListener('input', function(e){ t.note = e.target.value; autoGrow(e.target); });
    row.querySelector('.task-del').addEventListener('click', function(){
      currentTasks.splice(currentTasks.indexOf(t),1);
      renderTasks();
    });
    return row;
  }

  document.getElementById('addTaskBtn').addEventListener('click', function(){
    currentTasks.push({task:'', note:'', status:'waiting'});
    renderTasks();
  });

  document.getElementById('saveBtn').addEventListener('click', function(){
    var status = document.getElementById('saveStatus');
    var data = {
      savedAt: new Date().toISOString(),
      tasks: currentTasks.filter(function(t){ return t.task || t.note; })
    };
    status.textContent = '儲存中...';
    set(ref(db, 'dayTasks/' + toKey(cur)), data).then(function(){
      status.textContent = '已儲存';
    }).catch(function(){
      status.textContent = '儲存失敗';
    });
  });

  document.getElementById('prevDay').addEventListener('click', function(){
    cur.setDate(cur.getDate()-1);
    render();
  });
  document.getElementById('nextDay').addEventListener('click', function(){
    cur.setDate(cur.getDate()+1);
    render();
  });

  function renderHistory(allData){
    var list = document.getElementById('historyList');
    var keys = Object.keys(allData || {}).sort().reverse();
    if(keys.length === 0){
      list.innerHTML = '<div class="empty">還沒有任何紀錄。</div>';
      return;
    }
    list.innerHTML = '';
    keys.slice(0,14).forEach(function(dateStr){
      var data = allData[dateStr] || {};
      var tasks = data.tasks || [];
      var total = tasks.filter(function(t){ return t.task; }).length;
      var done = tasks.filter(function(t){ return t.task && t.status === 'done'; }).length;
      var item = document.createElement('div');
      item.className = 'history-item';
      item.innerHTML = '<span class="wk">' + dateStr + '</span><span class="ratio">' + done + ' / ' + total + ' 已完成</span>';
      item.addEventListener('click', function(){
        var parts = dateStr.split('-').map(Number);
        cur = new Date(parts[0], parts[1]-1, parts[2]);
        render();
      });
      list.appendChild(item);
    });
  }

  onValue(ref(db, 'dayTasks'), function(snapshot){
    renderHistory(snapshot.val());
  });

  render();
</script>
</body>
</html>
